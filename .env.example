# --- Server ---
SERVER_PORT=8080
APP_ENV=development
# Public base URL of THIS app (where the SPA is served and OAuth returns to).
APP_BASE_URL=http://localhost:8080

# --- Database ---
DATABASE_URL=postgres://txsurvey:txsurvey@localhost:5432/txsurvey?sslmode=disable

# --- Session (app-minted JWT in an httpOnly cookie) ---
# Must be >= 32 chars.
JWT_SECRET=change-me-to-at-least-32-characters-long-secret
SESSION_TTL=24h
# Set true in production (HTTPS). Keep false for local http.
COOKIE_SECURE=false
# Scope of the session cookie. Use "/" at the domain root, or the deploy subpath
# (e.g. "/txsurvey") so the cookie isn't shared with other apps on the same host.
COOKIE_PATH=/

# --- Google OAuth (sign-in only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# --- CORS (only needed for split-host dev: Vite :5173 -> API :8080) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
