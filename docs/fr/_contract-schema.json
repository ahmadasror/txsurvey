{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txsurvey/docs/fr/_contract-schema.json",
  "title": "txsurvey FR contract block (lean SDD, L3)",
  "description": "Machine-readable twin of each FR. Drift-detector source of truth: endpoints[] and db.writes[] are checked against the code/migrations. Lean: no RBAC/workflow/encryption blocks (txsurvey has none).",
  "type": "object",
  "additionalProperties": false,
  "required": ["fr_file", "covers"],
  "properties": {
    "fr_file": {
      "type": "string",
      "description": "Path to this FR markdown, e.g. docs/fr/survey/active/fr-forms.md"
    },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^FR-[A-Z0-9]+-[0-9]+$" },
      "description": "FR ids this file specifies, e.g. FR-FORM-001"
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "method", "path", "auth"],
        "properties": {
          "id": { "type": "string" },
          "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": {
            "type": "string",
            "description": "API path with {param} placeholders, e.g. /api/v1/forms/{id}"
          },
          "auth": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": ["session", "public"],
                "description": "session = creator cookie (SessionAuth); public = anonymous runner"
              }
            }
          }
        }
      }
    },
    "db": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "writes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["table"],
            "properties": {
              "table": { "type": "string" },
              "columns_declared": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "cross_links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adr_refs": { "type": "array", "items": { "type": "string" } },
        "sisters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "reason"],
        "properties": {
          "rule": { "type": "string" },
          "until": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
