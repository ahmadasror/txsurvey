# Production build config. The app is deployed under the /txsurvey subpath, so
# the SPA base path carries that prefix (asset URLs, router basename, API base,
# and runner share links are all derived from it).
#
# To deploy at a different subpath, change this (keep both slashes), e.g.
# "/forms/". To deploy at the domain root, set "/".
VITE_BASE=/txsurvey/
VITE_SITE_URL=https://brainzap.net
