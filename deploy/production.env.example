# Production env for the /txsurvey subpath deploy on ct.tuxceria.biz.id.
# Copy to the server as the app's .env (used by docker-compose or the binary).

SERVER_PORT=8080
APP_ENV=production

# Public origin of the app, INCLUDING the subpath. OAuth returns here after login.
APP_BASE_URL=https://brainzap.net/txsurvey

# Use a strong, random DB password (NOT the username). The Postgres host port is
# bound to loopback (see docker-compose.yml); the app connects over the compose
# network. sslmode=disable is acceptable only on that internal network.
DATABASE_URL=postgres://txsurvey:CHANGE_ME_strong_random@postgres:5432/txsurvey?sslmode=disable

# Session: must be >= 32 chars. HTTPS in prod -> COOKIE_SECURE=true.
# COOKIE_PATH scopes the cookie to the subpath so it isn't shared with other
# apps on ct.tuxceria.biz.id.
JWT_SECRET=CHANGE_ME_to_a_long_random_secret_at_least_32_chars
SESSION_TTL=24h
COOKIE_SECURE=true
COOKIE_PATH=/txsurvey

# Google OAuth — the redirect URL INCLUDES the subpath and must match the
# Authorized redirect URI registered in Google Cloud Console exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://brainzap.net/txsurvey/api/v1/auth/google/callback

# Same-origin in prod (SPA embedded), so CORS is unused; leave the dev default.
CORS_ALLOWED_ORIGINS=https://brainzap.net
